        "NodeName": "ZkTestNode"
    },
    "JsonRpc": {
        "Enabled": true,
        "Timeout": 20000,
        "Host": "127.0.0.1",
        "Port": 8545,
        "EnabledModules": [
            "Admin",
            "Eth",
            "Net",
            "Web3",
            "Engine"
        ],
        "EnginePort": 8551,
        "JwtSecretFile": "jwt.hex"
    },
    "Merge": {
        "Enabled": true
    }
}