{
    "$schema": "https://raw.githubusercontent.com/NethermindEth/core-scripts/refs/heads/main/schemas/config.json",
    "Init": {
        "ChainSpecPath": "chainspec/foundation.json",
        "GenesisHash": "0xd4e56740f876aef8c010b86a40d5f56745a118d0906a34e69aec8c0db1cb8fa3",
        "LogFileName": "zk_mainnet.log",
        "LogRules": "JsonRpc.Engine.*:Debug;Merge.*:Debug",
        "DiagnosticMode": "MemDb",
        "MemoryHint": 1024000000,
        "DiscoveryEnabled": false,
        "PeerManagerEnabled": false,
        "ProcessingEnabled": false
    },
    "JsonRpc": {
        "Enabled": true,
        "Timeout": 20000,
        "Host": "127.0.0.1",
        "Port": 8545,
        "EngineEnabledModules": ["Net", "Eth", "Subscribe", "Web3", "Engine"],
        "EnginePort": 8551
    },
    "Sync": {
        "NonValidatorNode": true,
        "DownloadReceiptsInFastSync": false,
        "DownloadBodiesInFastSync": false,
        "NetworkingEnabled": false,
        "SynchronizationEnabled": false
    },
    "TxPool": {
      "Size": 0,
      "BlobsSupport": "Disabled",
      "PersistentBroadcastEnabled": false
    },
    "Pruning": {
      "Mode": "None"
    },
    "Metrics": {
        "NodeName": "ZkMainnet"
    },
    "Merge": {
        "Enabled": true,
        "ZkValidationEnabled": true
    },
    "HealthChecks": {
      "Enabled": true
    }
}
